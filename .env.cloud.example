# Copiar a .env EN EL SERVIDOR (no subir a Git con contraseñas reales)
# Valores de ejemplo: cambiar todos los secretos.

APP_NAME=Ganatelo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# IP pública del VPS o tu dominio con https
APP_URL=https://tudominio.com

APP_TIMEZONE=America/La_Paz
APP_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
# Misma contraseña que MYSQL_ROOT_PASSWORD (usuario root de MySQL)
DB_PASSWORD=poner_la_misma_que_abajo

# Contraseña fuerte para MySQL (usuario root del contenedor)
MYSQL_ROOT_PASSWORD=poner_contraseña_fuerte

SESSION_DRIVER=cookie
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=file
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

GANATELO_DEMO_SIN_BILLETERA=true
